# ========== 易支付参数 ==========
# 自定义的 PID 和 KEY，填入 new-api 后台的「易支付」配置
EPAY_PID=10001
EPAY_KEY=your_epay_secret_key_here

# ========== 虎皮椒参数 ==========
# 从虎皮椒后台获取
HUPI_APPID=your_hupi_appid
HUPI_APPSECRET=your_hupi_appsecret
# 默认值一般不需要改，除非用的是虎皮椒其他 API 地址
# HUPI_API_URL=https://api.xunhupay.com/payment/do.html

# ========== 网络配置 ==========
# 本适配器的公网地址（虎皮椒回调会打到这里）
# 建议套 Cloudflare，确保国内可访问
BRIDGE_URL=https://pay.yourdomain.com

# new-api 的对外地址（适配器会把支付结果通知到这里）
NEW_API_BASE_URL=https://api.yourdomain.com

# ========== 可选配置 ==========
# 通知 new-api 的最大重试次数（默认 5）
# NOTIFY_MAX_RETRIES=5
# 重试基础间隔秒数，指数退避（默认 5）
# NOTIFY_RETRY_BASE_DELAY=5.0

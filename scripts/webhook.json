[
  {
    "id": "deploy",
    "execute-command": "/data/stable/aggre-api/scripts/deploy.sh",
    "command-working-directory": "/data/stable/aggre-api",
    "response-message": "Deploy triggered",
    "trigger-rule": {
      "and": [
        {
          "match": {
            "type": "payload-hmac-sha256",
            "secret": "aggre-webhook-secret-change-me",
            "parameter": {
              "source": "header",
              "name": "X-Hub-Signature-256"
            }
          }
        },
        {
          "match": {
            "type": "value",
            "value": "refs/heads/main",
            "parameter": {
              "source": "payload",
              "name": "ref"
            }
          }
        }
      ]
    }
  }
]
